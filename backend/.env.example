# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant

# JWT - Users
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_EXPIRES=7d

# JWT - Customers
JWT_CUSTOMER_ACCESS_SECRET=change_me_customer_access
JWT_CUSTOMER_REFRESH_SECRET=change_me_customer_refresh

# JWT - Super Admin
SUPER_ADMIN_JWT_SECRET=change_me_super_admin
SUPER_ADMIN_REFRESH_SECRET=change_me_super_admin_refresh

# Super admin seed
SUPER_ADMIN_EMAIL=admin@yoursaas.com
SUPER_ADMIN_PASSWORD=SuperAdmin1234!

# Default tenant seed (optional — omit to skip)
DEFAULT_TENANT_SLUG=restaurant-de-wever
DEFAULT_TENANT_NAME=Restaurant De Wever

# Default tenant admin seed (requires DEFAULT_TENANT_SLUG)
ADMIN_EMAIL=admin@restaurant.com
ADMIN_PASSWORD=Admin1234!

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

{
  "name": "restaurant-management",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npm run start:db && concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run start:backend\" \"npm run start:frontend\"",
    "start:db": "docker compose -f database/docker-compose.yml --env-file database/.env up -d",
    "start:backend": "npm --prefix backend run start:dev",
    "start:frontend": "npm --prefix frontend-backoffice run dev",
    "stop:db": "docker compose -f database/docker-compose.yml down",
    "stop:db:volumes": "docker compose -f database/docker-compose.yml down -v"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
